<% layout('layouts/boilerplate') %>

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h2 class="fw-bold text-light">Teacher Dashboard</h2>
  </div>
  <div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
      <div class="glass-card p-4 dashboard-stat">
        <h6 class="text-light-emphasis">Total Exams</h6>
        <h2 class="text-light">
          <%= exams.length %>
        </h2>
      </div>
    </div>
    <div class="col-md-6 col-lg-3">
      <div class="glass-card p-4 dashboard-stat">
        <h6 class="text-light-emphasis">Published Exams</h6>
        <h2 class="text-light">
          <%= exams.filter(e=> e.isPublished).length %>
        </h2>
      </div>
    </div>
    <div class="col-md-6 col-lg-3">
      <div class="glass-card p-4 dashboard-stat">
        <h6 class="text-light-emphasis">Approved Exams</h6>
        <h2 class="text-light">
          <%= exams.filter(e=> e.isApproved).length %>
        </h2>
      </div>
    </div>
    <div class="col-md-6 col-lg-3">
      <div class="glass-card p-4 dashboard-stat">
        <h6 class="text-light-emphasis">Total Questions</h6>
        <h2 class="text-light">
          <%= questions ? questions.length : 0 %>
        </h2>
      </div>
    </div>
  </div>



  <div class="glass-card p-4 mb-5">
  <h4 class="text-light mb-4">Announcements</h4>

  <% if (!announcements || announcements.length === 0) { %>
    <div class="alert alert-warning">No announcements available.</div>
  <% } else { %>
    <% announcements.forEach(item => { %>
      <div class="notice-item mb-3">
        <h6 class="text-light mb-1"><%= item.title %></h6>
        <p class="text-light-emphasis mb-1"><%= item.message %></p>
        <small class="text-light-emphasis">
          Posted by <%= item.createdBy?.name || "Admin" %> •
          <%= new Date(item.createdAt).toLocaleDateString() %>
        </small>
      </div>
    <% }) %>
  <% } %>
</div>



  <div class="glass-card p-4 mb-5">
    <h4 class="text-light mb-4">Create New Exam</h4>
    <form action="/exams/create" method="POST">
      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label text-light">Title</label>
          <input type="text" name="title" class="form-control premium-input" required>
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label text-light">Subject</label>
          <input type="text" name="subject" class="form-control premium-input" required>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label text-light">Description</label>
        <textarea name="description" rows="3" class="form-control premium-input" required></textarea>
      </div>

      <div class="row">
        <div class="col-md-3 mb-3">
          <label class="form-label text-light">Duration (minutes)</label>
          <input type="number" name="duration" class="form-control premium-input" required>
        </div>
        <div class="col-md-3 mb-3">
          <label class="form-label text-light">Passing Marks</label>
          <input type="number" name="passingMarks" class="form-control premium-input" required>
        </div>
        <div class="col-md-3 mb-3">
          <label class="form-label text-light">Start Time</label>
          <input type="datetime-local" name="startTime" class="form-control premium-input" required>
        </div>
        <div class="col-md-3 mb-3">
          <label class="form-label text-light">End Time</label>
          <input type="datetime-local" name="endTime" class="form-control premium-input" required>
        </div>
      </div>

      <button class="btn btn-primary px-4">Create Exam</button>
    </form>
  </div>

  <div class="glass-card p-4 mb-5">
    <h4 class="text-light mb-4">Add MCQ Question</h4>

    <% if (!exams || exams.length===0) { %>
      <div class="alert alert-warning">Please create an exam first. Then you can add MCQ questions.</div>
      <% } else { %>
        <form action="/exams/question/add" method="POST">
          <div class="mb-3">
            <label class="form-label text-light">Select Exam</label>
            <select name="examId" class="form-select premium-input" required>
              <% exams.forEach(exam=> { %>
                <option value="<%= exam._id %>">
                  <%= exam.title %>
                </option>
                <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label text-light">Question</label>
            <input type="text" name="questionText" class="form-control premium-input" required>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label text-light">Option 1</label>
              <input type="text" name="option1" class="form-control premium-input" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label text-light">Option 2</label>
              <input type="text" name="option2" class="form-control premium-input" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label text-light">Option 3</label>
              <input type="text" name="option3" class="form-control premium-input" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label text-light">Option 4</label>
              <input type="text" name="option4" class="form-control premium-input" required>
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label text-light">Correct Answer</label>
              <select name="correctAnswer" class="form-select premium-input" required>
                <option value="">Select correct option</option>
                <option value="option1">Option 1</option>
                <option value="option2">Option 2</option>
                <option value="option3">Option 3</option>
                <option value="option4">Option 4</option>
              </select>
            </div>

            <div class="col-md-6 mb-3">
              <label class="form-label text-light">Marks</label>
              <input type="number" name="marks" class="form-control premium-input" min="1" required>
            </div>
          </div>

          <button class="btn btn-success px-4">Add MCQ</button>
        </form>
        <% } %>
  </div>

  <div class="glass-card p-4 mb-5">
    <h4 class="text-light mb-4">My Exams</h4>

    <% if (!exams || exams.length===0) { %>
      <div class="alert alert-warning">No exams created yet.</div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle">
            <thead>
              <tr>
                <th>Title</th>
                <th>Subject</th>
                <th>Total Marks</th>
                <th>Approved</th>
                <th>Published</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% exams.forEach(exam=> { %>
                <tr>
                  <td>
                    <%= exam.title %>
                  </td>
                  <td>
                    <%= exam.subject %>
                  </td>
                  <td>
                    <%= exam.totalMarks || 0 %>
                  </td>
                  <td>
                    <% if (exam.isApproved) { %>
                      <span class="badge bg-success">Approved</span>
                      <% } else { %>
                        <span class="badge bg-warning text-dark">Pending</span>
                        <% } %>
                  </td>
                  <td>
                    <% if (exam.isPublished) { %>
                      <span class="badge bg-primary">Published</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Not Published</span>
                        <% } %>
                  </td>
                  <!-- <td>
                    <% if (!exam.isPublished) { %>
                      <form action="/exams/<%= exam._id %>/publish" method="POST" class="d-inline">
                        <button class="btn btn-sm btn-primary">Publish</button>
                      </form>
                      <% } else { %>
                        <button class="btn btn-sm btn-success" disabled>Live</button>
                        <% } %>
                  </td> -->

                  <td>
                    <a href="/exams/<%= exam._id %>/edit" class="btn btn-sm btn-outline-light">Edit</a>

                    <form action="/exams/<%= exam._id %>/delete" method="POST" class="d-inline">
                      <button class="btn btn-sm btn-danger">Delete</button>
                    </form>

                    <% if (!exam.isPublished) { %>
                      <form action="/exams/<%= exam._id %>/publish" method="POST" class="d-inline">
                        <button class="btn btn-sm btn-primary">Publish</button>
                      </form>
                      <% } else { %>
                        <button class="btn btn-sm btn-success" disabled>Live</button>
                        <% } %>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
  </div>



  <div class="glass-card p-4 mb-5">
    <h4 class="text-light mb-4">All Questions</h4>

    <% if (!questions || questions.length===0) { %>
      <div class="alert alert-warning">No questions added yet.</div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle">
            <thead>
              <tr>
                <th>Exam</th>
                <th>Question</th>
                <th>Correct</th>
                <th>Marks</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% questions.forEach(q=> { %>
                <tr>
                  <td>
                    <%= q.exam?.title || "N/A" %>
                  </td>
                  <td>
                    <%= q.questionText %>
                  </td>
                  <td>
                    <%= q.correctAnswer %>
                  </td>
                  <td>
                    <%= q.marks %>
                  </td>
                  <td>
                    <form action="/exams/question/<%= q._id %>/delete" method="POST" class="d-inline">
                      <button class="btn btn-danger btn-sm">Delete</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
  </div>


  <div class="glass-card p-4 mb-5">
    <h4 class="text-light mb-4">All Questions</h4>

    <% if (!questions || questions.length===0) { %>
      <div class="alert alert-warning">No questions added yet.</div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle">
            <thead>
              <tr>
                <th>Exam</th>
                <th>Question</th>
                <th>Correct</th>
                <th>Marks</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% questions.forEach(q=> { %>
                <tr>
                  <td>
                    <%= q.exam?.title || "N/A" %>
                  </td>
                  <td>
                    <%= q.questionText %>
                  </td>
                  <td>
                    <% if (q.correctAnswer==="option1" ) { %>
                      <%= q.options[0] %>
                        <% } else if (q.correctAnswer==="option2" ) { %>
                          <%= q.options[1] %>
                            <% } else if (q.correctAnswer==="option3" ) { %>
                              <%= q.options[2] %>
                                <% } else if (q.correctAnswer==="option4" ) { %>
                                  <%= q.options[3] %>
                                    <% } else { %>
                                      N/A
                                      <% } %>
                  </td>
                  <td>
                    <%= q.marks %>
                  </td>
                  <td>
                    <a href="/exams/question/<%= q._id %>/edit" class="btn btn-primary btn-sm">Edit</a>
                    <form action="/exams/question/<%= q._id %>/delete" method="POST" class="d-inline">
                      <button class="btn btn-danger btn-sm">Delete</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
  </div>





  <div class="glass-card p-4 mb-5">
    <h4 class="text-light mb-4">Student Results on My Exams</h4>

    <% if (!results || results.length===0) { %>
      <div class="alert alert-warning">No results available yet.</div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle">
            <thead>
              <tr>
                <th>Student</th>
                <th>Exam</th>
                <th>Marks</th>
                <th>Percentage</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% results.forEach(result=> { %>
                <tr>
                  <td>
                    <%= result.student?.name || "N/A" %>
                  </td>
                  <td>
                    <%= result.exam?.title || "N/A" %>
                  </td>
                  <td>
                    <%= result.obtainedMarks %> / <%= result.totalMarks %>
                  </td>
                  <td>
                    <%= result.percentage.toFixed(2) %>%
                  </td>
                  <td>
                    <span class="badge <%= result.status === 'Pass' ? 'bg-success' : 'bg-danger' %>">
                      <%= result.status %>
                    </span>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
  </div>



























