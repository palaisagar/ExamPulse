<% layout('layouts/boilerplate') %>

<div class="glass-card p-4">
  <h2 class="text-light mb-4">Edit Question</h2>

  <form action="/exams/question/<%= question._id %>/update" method="POST">
    <div class="mb-3">
      <label class="form-label text-light">Question</label>
      <input type="text" name="questionText" value="<%= question.questionText %>" class="form-control premium-input" required>
    </div>

    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label text-light">Option 1</label>
        <input type="text" name="option1" value="<%= question.options[0] %>" class="form-control premium-input" required>
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label text-light">Option 2</label>
        <input type="text" name="option2" value="<%= question.options[1] %>" class="form-control premium-input" required>
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label text-light">Option 3</label>
        <input type="text" name="option3" value="<%= question.options[2] %>" class="form-control premium-input" required>
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label text-light">Option 4</label>
        <input type="text" name="option4" value="<%= question.options[3] %>" class="form-control premium-input" required>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label text-light">Correct Answer</label>
        <select name="correctAnswer" class="form-select premium-input" required>
          <option value="option1" <%= question.correctAnswer === 'option1' ? 'selected' : '' %>>Option 1</option>
          <option value="option2" <%= question.correctAnswer === 'option2' ? 'selected' : '' %>>Option 2</option>
          <option value="option3" <%= question.correctAnswer === 'option3' ? 'selected' : '' %>>Option 3</option>
          <option value="option4" <%= question.correctAnswer === 'option4' ? 'selected' : '' %>>Option 4</option>
        </select>
      </div>

      <div class="col-md-6 mb-3">
        <label class="form-label text-light">Marks</label>
        <input type="number" name="marks" value="<%= question.marks %>" class="form-control premium-input" required>
      </div>
    </div>

    <button class="btn btn-primary px-4">Update Question</button>
    <a href="/teacher/dashboard" class="btn btn-outline-light px-4">Back</a>
  </form>
</div>