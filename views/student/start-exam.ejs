<% layout('layouts/boilerplate') %>

<div class="glass-card p-4 exam-wrapper">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
      <h2 class="fw-bold text-light mb-1"><%= exam.title %></h2>
      <p class="text-light-emphasis mb-0">Duration: <%= exam.duration %> minutes</p>
    </div>
    <div class="timer-box" id="timer" data-duration="<%= exam.duration %>">Time Left: --:--</div>
  </div>

  <div class="row g-4">
    <div class="col-lg-9">
      <form action="/attempts/submit/<%= exam._id %>" method="POST" id="examForm">
        <% questions.forEach((q, index) => { %>
          <div class="question-card mb-4 p-4" id="question-<%= index + 1 %>">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
              <h5 class="text-light mb-0">Q<%= index + 1 %>. <%= q.questionText %></h5>
              <span class="badge bg-secondary">Marks: <%= q.marks %></span>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input autosave-answer" type="radio" name="answers[<%= q._id %>]" value="option1" id="<%= q._id %>-1" data-question-id="<%= q._id %>" data-exam-id="<%= exam._id %>">
              <label class="form-check-label text-light" for="<%= q._id %>-1"><%= q.options[0] %></label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input autosave-answer" type="radio" name="answers[<%= q._id %>]" value="option2" id="<%= q._id %>-2" data-question-id="<%= q._id %>" data-exam-id="<%= exam._id %>">
              <label class="form-check-label text-light" for="<%= q._id %>-2"><%= q.options[1] %></label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input autosave-answer" type="radio" name="answers[<%= q._id %>]" value="option3" id="<%= q._id %>-3" data-question-id="<%= q._id %>" data-exam-id="<%= exam._id %>">
              <label class="form-check-label text-light" for="<%= q._id %>-3"><%= q.options[2] %></label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input autosave-answer" type="radio" name="answers[<%= q._id %>]" value="option4" id="<%= q._id %>-4" data-question-id="<%= q._id %>" data-exam-id="<%= exam._id %>">
              <label class="form-check-label text-light" for="<%= q._id %>-4"><%= q.options[3] %></label>
            </div>
          </div>
        <% }) %>

        <button type="submit" class="btn btn-success px-4">Submit Exam</button>
      </form>
    </div>

    <div class="col-lg-3">
      <div class="glass-card p-3 palette-box sticky-top">
        <h5 class="text-light mb-3">Question Palette</h5>
        <div class="d-flex flex-wrap gap-2">
          <% questions.forEach((q, index) => { %>
            <button type="button" class="palette-btn" data-target="question-<%= index + 1 %>"><%= index + 1 %></button>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>